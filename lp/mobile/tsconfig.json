{
  "compilerOptions": {
    "strict": true,
    "target": "esnext",
    "lib": ["es2022"],
    "module": "commonjs",
    "jsx": "react-native",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "extends": "expo/tsconfig.base",
  "exclude": ["node_modules"]
}
